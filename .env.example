# Copy this file to .env and fill in your values
# Never commit .env to source control

# From Azure AD App Registration → Overview
VITE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# From Azure AD → Overview (Directory/Tenant ID)
VITE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Comma-separated list of emails allowed to use Edit Mode
# Everyone else sees the report as read-only
VITE_EDITOR_EMAILS=you@adobe.com,colleague@adobe.com
